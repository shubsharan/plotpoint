{
  "name": "@plotpoint/db",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "push": "drizzle-kit push --config drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c ../config/oxlint.json src/",
    "lint:fix": "oxlint -c ../config/oxlint.json --fix src/",
    "format": "oxfmt src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@plotpoint/engine": "workspace:*",
    "drizzle-orm": "1.0.0-beta.19",
    "postgres": "^3.4.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@plotpoint/config": "workspace:*",
    "@types/node": "^24.6.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "1.0.0-beta.19",
    "tsdown": "^0.21.2",
    "typescript": "6.0.1-rc",
    "vitest": "^4.0.18"
  }
}
