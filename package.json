{
  "name": "plotpoint",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.4.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint -c packages/config/oxlint.json .",
