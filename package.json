    "format:fix": "oxfmt ."
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "drizzle-kit": "1.0.0-beta.19",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.2",
    "turbo": "^2.8.16",
    "typescript": "6.0.1-rc",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1"
}
